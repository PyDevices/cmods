From: Cursor Agent <cursoragent@cursor.com>
Date: Sat, 4 Jul 2026 07:42:20 +0000
Subject: [PATCH] Add Android prebuilt wheels (PEP 738 android_21_arm64_v8a)
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Extend cibuildwheel CI with an Android job (SDK + Java setup) that
publishes android_21_arm64_v8a and android_21_x86_64 wheels for
CPython 3.13–3.14 alongside Linux and Windows.

Document p4a/TestPyPI install paths and source fallback via
P4A_lvgl_cpython_DIR. Verified locally: cp313-android_arm64_v8a wheel.
---
 .github/workflows/publish-testpypi.yml | 34 +++++++++++++++++++++++++-
 BUILDING.md                            | 10 ++++++++
 PUBLISHING.md                          | 14 +++++++++--
 README.md                              |  9 ++++++-
 pyproject.toml                         | 16 +++++++++++-
 5 files changed, 78 insertions(+), 5 deletions(-)

diff --git a/.github/workflows/publish-testpypi.yml b/.github/workflows/publish-testpypi.yml
index 1c5896f..2d57508 100644
--- a/.github/workflows/publish-testpypi.yml
+++ b/.github/workflows/publish-testpypi.yml
@@ -94,8 +94,40 @@ jobs:
           name: cibw-wheels-${{ matrix.os }}
           path: wheelhouse/*.whl
 
+  build-android-wheels:
+    needs: prepare
+    runs-on: ubuntu-latest
+    if: github.repository == 'PyDevices/lv_cpython_mod'
+    steps:
+      - uses: actions/checkout@v4
+        with:
+          fetch-depth: 0
+          submodules: recursive
+
+      - uses: actions/setup-java@v4
+        with:
+          distribution: temurin
+          java-version: '17'
+
+      - uses: android-actions/setup-android@v3
+
+      - name: Write VERSION file
+        shell: bash
+        run: echo "${{ needs.prepare.outputs.version }}" > VERSION
+
+      - name: Build Android wheels
+        uses: pypa/cibuildwheel@v4.1.0
+        env:
+          CIBW_PLATFORM: android
+          ANDROID_HOME: ${{ env.ANDROID_SDK_ROOT }}
+
+      - uses: actions/upload-artifact@v4
+        with:
+          name: cibw-wheels-android
+          path: wheelhouse/*.whl
+
   publish:
-    needs: [prepare, build-wheels]
+    needs: [prepare, build-wheels, build-android-wheels]
     runs-on: ubuntu-latest
     if: github.repository == 'PyDevices/lv_cpython_mod'
     steps:
