 ## Install
 
-Prebuilt wheels are published as **`lvgl-cpython`** on [TestPyPI](https://test.pypi.org/project/lvgl-cpython/) (import as `lvgl`). CI builds a separate wheel for each CPython minor (3.10–3.14) on Linux x86_64 and Windows x64 — pip selects `cp312`, `cp314`, etc. to match your interpreter.
+Prebuilt wheels are published as **`lvgl-cpython`** on [TestPyPI](https://test.pypi.org/project/lvgl-cpython/) (import as `lvgl`). CI builds a separate wheel for each CPython minor (3.10–3.14) on Linux x86_64 and Windows x64, plus **Android** wheels for **3.13–3.14** (`android_21_arm64_v8a`, `android_21_x86_64` per [PEP 738](https://peps.python.org/pep-0738/)) — pip selects `cp312`, `cp314`, etc. to match your interpreter.
+
+**Android (python-for-android / pydisplay):** install the matching wheel from TestPyPI when building an APK, or let the `lvglcpython` p4a recipe fetch it (see [usdl2 `android_demo`](https://github.com/PyDevices/usdl2/tree/main/android_demo)):
+
+```bash
+pip install -i https://test.pypi.org/simple/ --extra-index-url https://pypi.org/simple/ \
+  --only-binary=:all: --platform android_21_arm64_v8a lvgl-cpython
+```
 
 ```bash
 pip install -i https://test.pypi.org/simple/ --extra-index-url https://pypi.org/simple/ lvgl-cpython
diff --git a/pyproject.toml b/pyproject.toml
index ff7ddd4..c2d3096 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -14,7 +14,7 @@ version = {file = "VERSION"}
 [tool.setuptools]
 packages = []
 
-# Wheel CI: one wheel per CPython minor (cp310…cp314) × Linux + Windows — see README.
+# Wheel CI: one wheel per CPython minor (cp310…cp314) × Linux + Windows + Android — see README.
 # Local reproduction: PUBLISHING.md § "Local wheel builds (cibuildwheel)" (Linux needs Docker).
 [tool.cibuildwheel]
 build = "cp310-* cp311-* cp312-* cp313-* cp314-*"
@@ -29,3 +29,17 @@ manylinux-x86_64-image = "manylinux_2_28"
 
 [tool.cibuildwheel.windows]
 archs = ["AMD64"]
+
+# PEP 738 Android tags: android_<api>_<arch> (e.g. android_21_arm64_v8a).
+# cibuildwheel 4.x builds Android wheels for CPython 3.13–3.14 only (matches p4a).
+# p4a / buildozer install these via --extra-index-url when a matching prebuilt wheel exists.
+[tool.cibuildwheel.android]
+archs = ["arm64_v8a", "x86_64"]
+environment = { ANDROID_API_LEVEL = "21" }
+test-command = "python -c \"import lvgl as lv; lv.init(); lv.deinit()\""
+# Emulator tests are optional in CI; wheels are smoke-tested on device via pydisplay APK.
+test-skip = "*"
+
+[[tool.cibuildwheel.overrides]]
+select = "*-android_*"
+build-frontend = "build"
