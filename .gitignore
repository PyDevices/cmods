# Local Python venv (if present)
.venv/

# Personal frozen manifest (local overrides)
my-manifest.*
main.py

# Local CircuitPython user config (copy from .example)
cp-user-config/user_post_mpconfigport.mk

# All cloned repos/directories at workspace root (micropython, user_cmodules, etc.)
/*/
# Local multi-repo symlinks (gh/pydevices layout — not committed)
/displayif
/graphics
/lv_bindings
/lv_circuitpython_mod
/lv_cpython_mod
/lv_micropython_cmod
/usdl2
/micropython
/circuitpython
/emsdk
/esp-idf
/SDL2-*
/lvgl
# Workspace tooling (not upstream clones)
!/scripts/
!/scripts/**
!/.cursor/
# Cursor IDE throwaways (rules/environment.json stay trackable)
.cursor/debug*
.cursor/plans/
!/cp-user-config/
!/.github/
!/.github/**
!/web/
!/web/**
