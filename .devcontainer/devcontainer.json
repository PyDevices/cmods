{
  "name": "cmods PyDevices workspace",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "vscode",
  "containerEnv": {
    "CMODS": "${containerWorkspaceFolder}"
  },
  "remoteEnv": {
    "CMODS": "${containerWorkspaceFolder}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-vscode.cpptools",
        "ms-vscode.cmake-tools",
        "ms-vscode.makefile-tools",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/lv_cpython_mod/.venv/bin/python",
        "python.analysis.extraPaths": [
          "${containerWorkspaceFolder}/pydisplay/src"
        ]
      }
    }
  }
}
